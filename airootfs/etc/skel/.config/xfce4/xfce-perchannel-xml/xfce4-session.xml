name: Build Eleven OS
on: [push]
jobs:
  build:
    runs-on: ubuntu-latest
    container:
      image: archlinux:latest
      options: --privileged
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4
      - name: Install Archiso
        run: pacman -Syu --noconfirm archiso
      - name: Build Eleven ISO
        run: |
          cp -r /usr/share/archiso/configs/releng/ ./profile
          cp packages.x86_64 ./profile/
          # Cette ligne copie tes dossiers airootfs (icônes, réglages)
          if [ -d "airootfs" ]; then cp -rv airootfs/* ./profile/airootfs/; fi
          # Active l'interface graphique (adieu le terminal !)
          ln -sf /usr/lib/systemd/system/lightdm.service ./profile/airootfs/etc/systemd/system/display-manager.service
          mkarchiso -v -w ./work -o ./out ./profile
      - name: Upload ISO Artifact
        uses: actions/upload-artifact@v4
        with:
          name: Eleven-OS-ISO
          path: out/*.iso
